{
  "name": "tikz-editor",
  "version": "0.1.0",
  "description": "WYSIWYG editor foundations for TikZ",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate:grammar": "lezer-generator src/syntax/grammar/tikz.grammar -o src/syntax/grammar/tikz-parser.ts",
    "build": "npm run generate:grammar && tsc -p tsconfig.json",
    "test": "npm run generate:grammar && vitest run",
    "test:watch": "npm run generate:grammar && vitest",
    "test:corpus": "npm run generate:grammar && vitest run test/corpus.spec.ts",
    "parse:corpus": "npm run test:corpus",
    "dev:web": "cd web && npm run dev"
  },
  "keywords": [
    "tikz",
    "lezer",
    "parser"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@lezer/common": "^1.3.0",
    "@lezer/lr": "^1.4.3"
  },
  "devDependencies": {
    "@lezer/generator": "^1.8.0",
    "@types/node": "^22.13.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
