{
  "name": "tikz-editor",
  "version": "0.3.0",
  "description": "WYSIWYG editor foundations for TikZ",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "codespaces:startup": "bash scripts/codespaces/startup.sh",
    "version:bump": "node scripts/bump-version.mjs",
    "generate:grammar": "npm run -w @tikz-editor/core generate:grammar",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/full/ --cache-strategy content",
    "lint:prod": "eslint . --cache --cache-location node_modules/.cache/eslint/prod/ --cache-strategy content --max-warnings=0 --ignore-pattern 'coverage/**' --ignore-pattern 'test/**' --ignore-pattern 'apps/desktop/e2e/**' --ignore-pattern 'apps/web/e2e/**' --ignore-pattern 'apps/web/profiling/**' --ignore-pattern 'apps/*/src-tauri/target/**' --ignore-pattern 'scripts/**' --ignore-pattern 'apps/*/scripts/**' --ignore-pattern '**/*.config.*' --ignore-pattern '**/tmp-*'",
    "lint:no-unnecessary-condition": "eslint . --no-cache --format json --output-file node_modules/.cache/eslint/no-unnecessary-condition.json --rule '@typescript-eslint/no-unnecessary-condition:warn' --ignore-pattern 'coverage/**' --ignore-pattern 'test/**' --ignore-pattern 'apps/desktop/e2e/**' --ignore-pattern 'apps/web/e2e/**' --ignore-pattern 'apps/web/profiling/**' --ignore-pattern 'scripts/**' --ignore-pattern 'apps/*/scripts/**' --ignore-pattern '**/*.config.*' --ignore-pattern '**/tmp-*'",
    "lint:test": "eslint test apps/web/e2e apps/web/profiling apps/desktop/e2e --cache --cache-location node_modules/.cache/eslint/test/ --cache-strategy content --max-warnings=0",
    "lint:ci": "npm run lint:prod",
    "typecheck": "tsc -p tsconfig.json --noEmit --incremental --tsBuildInfoFile node_modules/.cache/tsc/typecheck.tsbuildinfo && node scripts/check-coordinate-typing.mjs",
    "build": "npm run -w @tikz-editor/core build",
    "test": "npm run generate:grammar && vitest run",
    "test:coverage": "npm run generate:grammar && vitest run --coverage",
    "test:capabilities": "npm run generate:grammar && vitest run test/capabilities.spec.ts",
    "test:watch": "npm run generate:grammar && vitest",
    "test:corpus": "npm run generate:grammar && vitest run test/corpus.spec.ts",
    "parse:corpus": "npm run test:corpus",
    "compare:renderers": "node scripts/compare-tikz-renderers.mjs",
    "compare:paragraph-breaks": "node scripts/compare-paragraph-breaks.mjs",
    "compare:arrows": "node scripts/compare-arrow-fixtures.mjs",
    "compare:pgf-docs": "node scripts/compare-pgf-docs-renderings.mjs",
    "compare:kottwitz-book": "node scripts/compare-pgf-docs-renderings.mjs --mode kottwitz-book",
    "compare:kolda-book": "node scripts/compare-pgf-docs-renderings.mjs --mode kolda-book",
    "generate:font-previews": "node scripts/generate-font-previews.mjs",
    "generate:shape-previews": "npx tsx apps/web/scripts/generate-node-shape-previews.ts",
    "debug:multiline": "npm run -w @tikz-editor/web debug:multiline --",
    "bench:incremental-drag": "node scripts/benchmark-incremental-drag.mjs",
    "profile:web": "npm run -w @tikz-editor/web profile --",
    "profile:web:analyze": "npm run -w @tikz-editor/web profile:analyze --",
    "profile:web:compare": "npm run -w @tikz-editor/web profile:compare --",
    "profile:web:compare-report": "npm run -w @tikz-editor/web profile:compare-report --",
    "dev:web": "npm run -w @tikz-editor/web dev",
    "dev:landing": "npm run -w @tikz-editor/landing dev",
    "dev:desktop": "npm run -w @tikz-editor/desktop tauri:dev",
    "build:landing": "npm run -w @tikz-editor/landing build",
    "capture:landing-screenshots": "npm run -w @tikz-editor/landing capture:screenshots --",
    "build:desktop": "npm run -w @tikz-editor/desktop tauri:build",
    "test:e2e": "npm run -w @tikz-editor/web test:e2e --",
    "test:e2e:firefox": "npm run -w @tikz-editor/web test:e2e:firefox --",
    "test:e2e:webkit": "npm run -w @tikz-editor/web test:e2e:webkit --",
    "test:e2e:all-browsers": "npm run -w @tikz-editor/web test:e2e:all-browsers --",
    "test:e2e:ci": "npm run -w @tikz-editor/web test:e2e:ci --",
    "test:desktop:e2e": "npm run -w @tikz-editor/desktop test:e2e --"
  },
  "keywords": [
    "tikz",
    "lezer",
    "parser"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint-react/eslint-plugin": "^5.8.5",
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "keynote-clipboard": "^1.2.0"
  }
}
