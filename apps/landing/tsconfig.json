{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@tikz-editor/app": ["../../packages/app/src/index.ts"],
      "@tikz-editor/app/landing-assets": ["../../packages/app/src/landing-assets.ts"],
      "tikz-editor/*": ["../../packages/core/src/*"]
    }
  },
  "include": ["src"]
}
