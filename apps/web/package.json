{
  "name": "@tikz-editor/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate:example-previews": "node --import tsx scripts/generate-open-example-previews.ts",
    "debug:multiline": "node --import tsx scripts/capture-multiline-debug.ts",
    "dev": "npm run generate:example-previews && vite",
    "build": "npm run generate:example-previews && vite build",
    "test:e2e": "env -u NO_COLOR FORCE_COLOR=0 playwright test",
    "test:e2e:headed": "env -u NO_COLOR FORCE_COLOR=0 playwright test --headed",
    "test:e2e:ci": "env -u NO_COLOR FORCE_COLOR=0 playwright test --reporter=line",
    "profile": "node --import tsx scripts/run-profiling.ts --all",
    "profile:landing": "env -u NO_COLOR FORCE_COLOR=0 playwright test --config profiling/playwright.landing.config.ts profiling/profile-landing.spec.ts",
    "profile:analyze": "node ../../scripts/analyze-cpuprofile.mjs",
    "profile:compare": "node ../../scripts/analyze-cpuprofile.mjs compare",
    "profile:compare-report": "node ../../scripts/analyze-cpuprofile.mjs compare-report"
  },
  "dependencies": {
    "@tikz-editor/app": "0.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
