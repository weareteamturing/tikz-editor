{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["test", "scripts", "packages/core/src", "packages/app/src", "apps/web/src"],
  "exclude": ["node_modules", "packages/core/dist", "apps/web/dist"]
}
