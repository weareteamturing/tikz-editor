{
  "name": "@tikz-editor/core",
  "version": "0.1.0",
  "description": "Reusable TikZ parser/semantic/SVG engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate:grammar": "lezer-generator src/syntax/grammar/tikz.grammar -o src/syntax/grammar/tikz-parser.ts",
