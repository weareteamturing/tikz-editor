  "/tikz/nodes in empty cells": {
    "type": "key",
    "signatureHtml": "<kbd>/tikz/nodes in empty cells=</kbd>⟨<i>true or false</i>⟩",
    "defaultHtml": "(default <kbd>true</kbd>)",
    "snippetHtml": "<p> When set to <code>true</code>, a node (with empty contents) is put in empty cells. Normally, empty cells are just, well, empty. The style can be used together with both a <code>matrix of nodes</code> and a <code>matrix of math nodes</code>. </p>",
    "page": "library-matrix",
    "anchor": "pgf./tikz/nodes:in:empty:cells",
    "href": "https://tikz.dev/library-matrix#pgf./tikz/nodes%3Ain%3Aempty%3Acells"
  },
