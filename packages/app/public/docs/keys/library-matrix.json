    "type": "key",
    "signatureHtml": "<kbd>/tikz/matrix of math nodes</kbd>",
    "defaultHtml": "(no value)",
    "snippetHtml": "<p> This style is almost the same as the previous style, only <code>$</code> is added at the beginning and at the end of each node, so math mode will be switched on in all nodes. </p>",
