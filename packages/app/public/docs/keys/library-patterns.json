  "\\tikzdeclarepattern": {
    "type": "command",
    "signatureHtml": "<kbd>\\tikzdeclarepattern</kbd>{⟨<i>config</i>⟩}",
    "defaultHtml": "",
    "snippetHtml": "<p> A pattern declared with <code>\\pgfdeclarepattern</code> can only execute pgf code. This command extends the functionality to also allow TikZ code. All the same keys of <code>\\pgfdeclarepattern</code> are valid, but some of them have been overloaded to give a more natural TikZ syntax. </p>",
    "page": "library-patterns",
    "anchor": "pgf.back/tikzdeclarepattern",
    "href": "https://tikz.dev/library-patterns#pgf.back/tikzdeclarepattern"
  },
