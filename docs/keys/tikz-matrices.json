    "signatureHtml": "<kbd>/tikz/column sep=</kbd>⟨<i>spacing list</i>⟩",
    "defaultHtml": "(no default)",
    "snippetHtml": "<p> This option sets a default space that is added between every two columns. This space can be positive or negative and is zero by default. The ⟨<i>spacing list</i>⟩ normally contains a single dimension like <code>2pt</code>. </p>",
