  "/tikz/every cell": {
    "type": "style",
    "signatureHtml": "<kbd>/tikz/every cell=</kbd>{⟨<i>row</i>⟩}{⟨<i>column</i>⟩}",
    "defaultHtml": "(style, no default, initially <kbd>empty</kbd>)",
    "snippetHtml": "<p> This style is installed at the beginning of each cell picture with the two parameters being the current ⟨<i>row</i>⟩ and ⟨<i>column</i>⟩ of the cell. Note that setting this style to <code>draw</code> will <em>not</em> cause all nodes to be drawn since the <code>draw</code> option has to be passed to each node individually. </p><p> Inside this style (and inside all cells), the current ⟨<i>row</i>⟩ and ⟨<i>column</i>⟩ number are also accessible via the counters <code>\\pgfmatrixcurrentrow</code> and <code>\\pgfmatrixcurrentcolumn</code>. </p>",
    "page": "tikz-matrices",
    "anchor": "pgf./tikz/every:cell",
    "href": "https://tikz.dev/tikz-matrices#pgf./tikz/every%3Acell"
  },
